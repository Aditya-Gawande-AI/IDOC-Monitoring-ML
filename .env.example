APP_NAME=idoc-ml-insights
APP_ENV=prod
LOG_LEVEL=INFO

IDOC_API_URL=https://your-api.example.com/Z_IDOCSTATUS1_SRV/OStatusSet?$filter=E_Flag eq 'I'
IDOC_API_USERNAME=developer
IDOC_API_PASSWORD=replace_me
IDOC_ORIGIN_HEADER=*
VERIFY_TLS=true
REQUEST_TIMEOUT_SECONDS=30

FETCH_INTERVAL_MINUTES=15
MIN_TRAINING_ROWS=300
